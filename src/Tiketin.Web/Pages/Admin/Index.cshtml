@page "/admin"
@using System.Text.Json
@model Tiketin.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var trendLabels = JsonSerializer.Serialize(Model.Trends.Select(t => t.Date.ToString("dd/MM")));
    var trendValues = JsonSerializer.Serialize(Model.Trends.Select(t => t.Count));
    var categoryLabels = JsonSerializer.Serialize(Model.Summary.ByCategory.Select(c => c.Category));
    var categoryValues = JsonSerializer.Serialize(Model.Summary.ByCategory.Select(c => c.Count));
}
<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="page-header__sub">Ringkasan operasional helpdesk, bulan berjalan.</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: calc(var(--space) * 4); margin-bottom: calc(var(--space) * 6);">
    <div class="card">
        <p class="text-xs text-3">Tiket aktif</p>
        <p class="mono" style="font-size: 1.75rem; font-weight: 600;">@Model.ActiveTickets</p>
        <p class="text-xs text-2">dari @Model.Summary.TotalTickets total</p>
    </div>
    <div class="card">
        <p class="text-xs text-3">Tiket bulan ini</p>
        <p class="mono" style="font-size: 1.75rem; font-weight: 600;">@Model.Summary.CreatedThisMonth</p>
        <p class="text-xs text-2">@Model.Summary.ResolvedThisMonth selesai</p>
    </div>
    <div class="card">
        <p class="text-xs text-3">SLA respon (30 hari)</p>
        <p class="mono" style="font-size: 1.75rem; font-weight: 600; @(Model.Sla.ResponseRate < 80 ? "color: var(--status-critical);" : "")">@Model.Sla.ResponseRate%</p>
        <p class="text-xs text-2">penyelesaian @Model.Sla.ResolutionRate%</p>
    </div>
    <div class="card">
        <p class="text-xs text-3">Rata-rata kepuasan</p>
        <p class="mono" style="font-size: 1.75rem; font-weight: 600;">@(Model.Summary.AverageRating?.ToString("0.0") ?? "-")</p>
        <p class="text-xs text-2">dari skala 5</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 3fr 2fr; gap: calc(var(--space) * 4); margin-bottom: calc(var(--space) * 6);">
    <div class="card">
        <p class="text-sm" style="font-weight: 500; margin-bottom: calc(var(--space) * 3);">Tiket masuk, 30 hari terakhir</p>
        <canvas id="trend-chart" height="110" role="img"
                aria-label="Grafik tiket masuk per hari selama 30 hari terakhir"></canvas>
    </div>
    <div class="card">
        <p class="text-sm" style="font-weight: 500; margin-bottom: calc(var(--space) * 3);">Sebaran kategori</p>
        <canvas id="category-chart" height="180" role="img"
                aria-label="Grafik jumlah tiket per kategori"></canvas>
    </div>
</div>

<div class="card" style="padding: 0;">
    <p class="text-sm" style="font-weight: 500; padding: calc(var(--space) * 4) calc(var(--space) * 4) calc(var(--space) * 2);">
        Performa teknisi
    </p>
    <table class="table">
        <thead>
            <tr>
                <th>Teknisi</th>
                <th>Selesai</th>
                <th>Aktif</th>
                <th>Rata-rata penyelesaian</th>
                <th>Rata-rata rating</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tech in Model.Technicians)
            {
                <tr>
                    <td>@tech.TechnicianName</td>
                    <td class="mono">@tech.ResolvedCount</td>
                    <td class="mono">@tech.ActiveCount</td>
                    <td class="mono text-2">@(tech.AverageResolutionHours is { } h ? $"{h:0.#} jam" : "-")</td>
                    <td class="mono text-2">@(tech.AverageRating is { } r ? $"{r:0.00} / 5" : "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script>
        (function () {
            "use strict";
            var css = getComputedStyle(document.documentElement);
            var text2 = css.getPropertyValue("--text-2").trim();
            var text3 = css.getPropertyValue("--text-3").trim();
            var border = css.getPropertyValue("--border").trim();
            var accent = css.getPropertyValue("--accent").trim();

            Chart.defaults.font.family = css.getPropertyValue("--font-ui").trim();
            Chart.defaults.font.size = 11;
            Chart.defaults.color = text3;

            new Chart(document.getElementById("trend-chart"), {
                type: "line",
                data: {
                    labels: @Html.Raw(trendLabels),
                    datasets: [{
                        data: @Html.Raw(trendValues),
                        borderColor: accent,
                        backgroundColor: "transparent",
                        borderWidth: 1.5,
                        pointRadius: 0,
                        pointHitRadius: 8,
                        tension: 0.3
                    }]
                },
                options: {
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 10 } },
                        y: { beginAtZero: true, grid: { color: border }, ticks: { precision: 0 } }
                    },
                    animation: window.matchMedia("(prefers-reduced-motion: reduce)").matches ? false : { duration: 300 }
                }
            });

            new Chart(document.getElementById("category-chart"), {
                type: "bar",
                data: {
                    labels: @Html.Raw(categoryLabels),
                    datasets: [{
                        data: @Html.Raw(categoryValues),
                        backgroundColor: text2,
                        borderRadius: 2,
                        barThickness: 14
                    }]
                },
                options: {
                    indexAxis: "y",
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { beginAtZero: true, grid: { color: border }, ticks: { precision: 0 } },
                        y: { grid: { display: false } }
                    },
                    animation: window.matchMedia("(prefers-reduced-motion: reduce)").matches ? false : { duration: 300 }
                }
            });
        })();
    </script>
}
